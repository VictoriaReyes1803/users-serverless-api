# Integration test configuration — copy to .env.integration and fill in values
# Get API_URL from:             terraform output api_url          (inside infra/)
# Get COGNITO_CLIENT_ID from:   terraform output cognito_client_id
# Get COGNITO_USER_POOL_ID from: terraform output cognito_user_pool_id
#
# AWS credentials must be configured in the environment (AWS_PROFILE, or
# AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY). The account needs:
#   cognito-idp:AdminCreateUser, cognito-idp:AdminSetUserPassword, cognito-idp:AdminDeleteUser

API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
AWS_REGION=us-east-1
